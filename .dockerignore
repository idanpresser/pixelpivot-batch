# Ignore all build and deployment outputs
out/
deploy/
dist/
build/
pixelpivot_batch.egg-info/

# Ignore local Python virtual environments and caches
.venv/
.venv*/
.mypy_cache/
.pytest_cache/
.ruff_cache/
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore local databases and dynamic logs
data/
*.db
*.log
*.log.*
.beads/
.antigravitycli/
. remember/
.coverage

# Ignore host Node dependencies (rebuilt inside Docker stage 1)
**/node_modules/
services/sharp-daemon/node_modules/

# Ignore test code and heavy testing assets
tests/
test_pics/
image_samples/
converted_images/
corrupt_or_failed/
dummy_out/
test_results_snippet.txt
MagicMock/

# Ignore docs, scripts, task tracking — not app code
docs/
tasks/
scripts/
tools/
air_gapped_guide.md
codebase_review_report.json
*.md

# Ignore IDE / AI assistant state
.claude/
.remember/

# Ignore vendored binaries and offline installers
bin/
vendor/
scratch/
python-3.14.5-embed-amd64/
python-3.14.5-embed-amd64.zip

# Ignore Git files
.git/
.gitignore
.gitattributes
.worktrees/
